# Hugging Face 공개 instruct 모델 (로컬 추론)
# 7B: 품질↑ RAM·첫 로드·추론 시간↑
CHATBOT_MODEL_ID=Qwen/Qwen2.5-1.5B-Instruct
# 4bit NF4 (NVIDIA CUDA). Mac은 자동으로 fp16 MPS
CHATBOT_LOAD_IN_4BIT=true
# 다국어 임베딩
CHATBOT_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# RAG 검색 개수
CHATBOT_TOP_K=4
# 검색 청크 → LLM 답변 (고정)
CHATBOT_ANSWER_MODE=llm_rag
CHATBOT_DISTANCE_HIGH_MAX=0.35
CHATBOT_DISTANCE_LOW_MAX=0.55
CHATBOT_PENDING_TTL_SEC=600
